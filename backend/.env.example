# ── MySQL 数据库（生产部署）──
# 先创建数据库：CREATE DATABASE wangzhe_betting CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
DATABASE_URL="mysql://root:your_password@localhost:3306/wangzhe_betting"

# ── 或 SQLite（本地开发）──
# DATABASE_URL="file:./dev.db"

# JWT 密钥（生产环境请更换为高强度随机字符串）
JWT_SECRET="change-me-to-a-random-string"

# 服务端口
PORT=3001

# CORS 允许的前端地址
CORS_ORIGIN="http://localhost:5173"

# 上传文件目录
UPLOAD_DIR="./uploads"
